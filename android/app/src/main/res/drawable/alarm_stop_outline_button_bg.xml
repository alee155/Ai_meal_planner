<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#19E24B4A" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#99E24B4A" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#F8FFF9" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#99E24B4A" />
        </shape>
    </item>
</selector>

