<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/alarm_body_bg">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/alarm_header_gradient"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="28dp">

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginTop="-50dp"
            android:layout_marginEnd="-50dp"
            android:background="@drawable/alarm_header_orb_a" />

        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="-40dp"
            android:layout_marginBottom="-30dp"
            android:background="@drawable/alarm_header_orb_b" />

        <LinearLayout
            android:id="@+id/badgeRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/alarm_header_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp">

                <View
                    android:id="@+id/pulseDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/alarm_pulse_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="Meal alarm ringing"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/pulseRingContainer"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_below="@id/badgeRow"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp">

            <View
                android:id="@+id/pulseRing"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:background="@drawable/alarm_pulse_ring" />

            <FrameLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:background="@drawable/alarm_bell_circle">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_alarm_bell"
                    android:tint="#FFFFFF" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/alarmCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/pulseRingContainer"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            android:textSize="58sp"
            android:textStyle="bold"
            tools:text="8:30 AM" />

        <TextView
            android:id="@+id/alarmCurrentDateCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/alarmCurrentTime"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:textColor="#D2EFE0"
            android:textSize="11sp"
            tools:text="Tuesday, April 14" />

        <LinearLayout
            android:id="@+id/scheduledChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/alarmCurrentDateCenter"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"
            android:background="@drawable/alarm_header_chip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_alarm_schedule"
                android:tint="#D6F0E4" />

            <TextView
                android:id="@+id/alarmScheduledTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#E8FAF1"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Scheduled for 8:00 AM" />
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/alarm_card_bg"
                android:orientation="horizontal"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/alarm_icon_tile">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_alarm_meal"
                        android:tint="#1D9E75" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/alarmTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#122015"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="Breakfast reminder" />

                    <TextView
                        android:id="@+id/alarmInstruction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="6dp"
                        android:textColor="#33463A"
                        android:textSize="14sp"
                        tools:text="Time to complete your meal and follow your nutrition plan." />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/alarm_hint_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="11dp"
                android:paddingEnd="14dp"
                android:paddingBottom="11dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_alarm_tip"
                    android:tint="#1D9E75" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:lineSpacingExtra="3dp"
                    android:text="Snooze pauses for 30 s · Stop silences &amp; keeps your schedule"
                    android:textColor="#203127"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:text="SWIPE TO SNOOZE"
                android:textColor="#7A9A87"
                android:textSize="10sp"
                android:textStyle="bold" />

            <com.example.ai_meal_planner.widgets.SwipeActionView
                android:id="@+id/alarmSnoozeSlider"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:text="SWIPE TO STOP"
                android:textColor="#7A9A87"
                android:textSize="10sp"
                android:textStyle="bold" />

            <com.example.ai_meal_planner.widgets.SwipeActionView
                android:id="@+id/alarmStopSlider"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
