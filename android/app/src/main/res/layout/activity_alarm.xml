<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@drawable/alarm_bg_gradient">

    <!-- ── Status bar row ───────────────────────────────────────────────── -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingTop="22dp" android:paddingEnd="20dp" android:paddingBottom="8dp">

        <!-- Status pill (text changes per slot) -->
        <LinearLayout android:id="@+id/statusPill" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/alarm_status_pill" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="12dp" android:paddingTop="6dp" android:paddingEnd="12dp" android:paddingBottom="6dp">

            <View android:id="@+id/pulseDot" android:layout_width="7dp" android:layout_height="7dp" android:background="@drawable/alarm_pulse_dot" />

            <TextView android:id="@+id/statusLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Alarm ringing" android:textColor="#203127" android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Bell icon with pulse ring -->
        <FrameLayout android:layout_width="56dp" android:layout_height="56dp">

            <View android:id="@+id/pulseRing" android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="center" android:background="@drawable/alarm_pulse_ring" />

            <FrameLayout android:id="@+id/bellCircle" android:layout_width="48dp" android:layout_height="48dp" android:layout_gravity="center" android:background="@drawable/alarm_bell_circle">

                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:src="@drawable/ic_alarm_bell" android:tint="#FFFFFF" />
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- ── Time block ───────────────────────────────────────────────────── -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingBottom="6dp">

        <TextView android:id="@+id/alarmCurrentTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#122015" android:textSize="54sp" android:textStyle="bold" android:fontFamily="sans-serif" tools:text="7:00 AM" />

        <TextView android:id="@+id/alarmCurrentDateCenter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="#33463A" android:textSize="12sp" tools:text="Wednesday, June 7" />

        <!-- Window pill: "Window: 7:00 AM – 9:00 AM PKT" -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/alarm_status_pill" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="14dp" android:paddingTop="8dp" android:paddingEnd="14dp" android:paddingBottom="8dp">

            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_alarm_schedule" android:tint="#388E3C" />

            <TextView android:id="@+id/alarmWindowPill" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textColor="#203127" android:textSize="12sp" android:textStyle="bold" tools:text="Window: 7:00 AM – 9:00 AM PKT" />
        </LinearLayout>

        <!-- Reminder count badge "Reminder 1 of 3" -->
        <TextView android:id="@+id/alarmSlotBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/alarm_window_badge_bg" android:paddingStart="12dp" android:paddingTop="5dp" android:paddingEnd="12dp" android:paddingBottom="5dp" android:textColor="#1B5E20" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" tools:text="Reminder 1 of 3" />
    </LinearLayout>

    <!-- ── Slot progress stepper ─────────────────────────────────────────── -->
    <LinearLayout android:id="@+id/stepperSection" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="24dp" android:paddingTop="8dp" android:paddingEnd="24dp" android:paddingBottom="4dp" android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MEAL WINDOW PROGRESS" android:textColor="#456B52" android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="8dp" />

        <!-- Dot + line row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">

            <FrameLayout android:id="@+id/slotDot1" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/alarm_slot_dot_pending">
                <TextView android:id="@+id/slotDot1Text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="1" android:textSize="10sp" android:textStyle="bold" android:textColor="#7A9A87" />
            </FrameLayout>

            <View android:id="@+id/slotLine1" android:layout_width="0dp" android:layout_height="1.5dp" android:layout_weight="1" android:background="#C4DEC8" />

            <FrameLayout android:id="@+id/slotDot2" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/alarm_slot_dot_pending">
                <TextView android:id="@+id/slotDot2Text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="2" android:textSize="10sp" android:textStyle="bold" android:textColor="#7A9A87" />
            </FrameLayout>

            <View android:id="@+id/slotLine2" android:layout_width="0dp" android:layout_height="1.5dp" android:layout_weight="1" android:background="#C4DEC8" />

            <FrameLayout android:id="@+id/slotDot3" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/alarm_slot_dot_pending">
                <TextView android:id="@+id/slotDot3Text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="3" android:textSize="10sp" android:textStyle="bold" android:textColor="#7A9A87" />
            </FrameLayout>
        </LinearLayout>

        <!-- Slot time labels -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="5dp">

            <TextView android:id="@+id/slotLabel1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#456B52" android:textSize="9sp" tools:text="Start · 7:00" />

            <TextView android:id="@+id/slotLabel2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#456B52" android:textSize="9sp" tools:text="Mid · 8:00" />

            <TextView android:id="@+id/slotLabel3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#456B52" android:textSize="9sp" tools:text="Close · 8:30" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Scrollable body ───────────────────────────────────────────────── -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true" android:overScrollMode="never">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="20dp" android:paddingTop="10dp" android:paddingEnd="20dp" android:paddingBottom="14dp">

            <!-- Meal info card -->
            <LinearLayout android:id="@+id/mealCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/alarm_card_bg" android:orientation="horizontal" android:padding="16dp">

                <!-- Meal icon tile -->
                <FrameLayout android:id="@+id/mealIconTile" android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/alarm_icon_tile">

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_alarm_meal" android:tint="#388E3C" />
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:layout_weight="1" android:orientation="vertical">

                    <TextView android:id="@+id/alarmTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#122015" android:textSize="17sp" android:textStyle="bold" android:fontFamily="sans-serif" tools:text="Breakfast Time!" />

                    <TextView android:id="@+id/alarmInstruction" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:lineSpacingExtra="3dp" android:textColor="#33463A" android:textSize="13sp" tools:text="Your breakfast window is open. Time to eat!" />

                    <!-- Macro badges row -->
                    <LinearLayout android:id="@+id/macroRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal" android:visibility="gone">

                        <TextView android:id="@+id/macroKcal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/alarm_macro_badge_bg" android:paddingStart="8dp" android:paddingTop="4dp" android:paddingEnd="8dp" android:paddingBottom="4dp" android:textColor="#1B5E20" android:textSize="10sp" android:textStyle="bold" tools:text="697 kcal" />

                        <TextView android:id="@+id/macroProtein" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="5dp" android:background="@drawable/alarm_macro_badge_bg" android:paddingStart="8dp" android:paddingTop="4dp" android:paddingEnd="8dp" android:paddingBottom="4dp" android:textColor="#1B5E20" android:textSize="10sp" android:textStyle="bold" tools:text="P 37g" />

                        <TextView android:id="@+id/macroCarbs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="5dp" android:background="@drawable/alarm_macro_badge_bg" android:paddingStart="8dp" android:paddingTop="4dp" android:paddingEnd="8dp" android:paddingBottom="4dp" android:textColor="#7B4F00" android:textSize="10sp" android:textStyle="bold" tools:text="C 82g" />

                        <TextView android:id="@+id/macroFat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="5dp" android:background="@drawable/alarm_macro_badge_bg" android:paddingStart="8dp" android:paddingTop="4dp" android:paddingEnd="8dp" android:paddingBottom="4dp" android:textColor="#7B2000" android:textSize="10sp" android:textStyle="bold" tools:text="F 27g" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Hint card -->
            <LinearLayout android:id="@+id/hintCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/alarm_hint_bg" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="14dp" android:paddingTop="12dp" android:paddingEnd="14dp" android:paddingBottom="12dp">

                <ImageView android:layout_width="15dp" android:layout_height="15dp" android:src="@drawable/ic_alarm_tip" android:tint="#388E3C" />

                <TextView android:id="@+id/hintText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:lineSpacingExtra="3dp" android:textColor="#203127" android:textSize="12sp" tools:text="Snooze pauses for 30 s. Mark as done when you finish eating." />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ── Actions ──────────────────────────────────────────────────────── -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="20dp" android:paddingTop="8dp" android:paddingEnd="20dp" android:paddingBottom="24dp">

        <!-- "I'm done eating" — primary on pre-close, secondary otherwise -->
        <TextView android:id="@+id/alarmDoneButton" android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/alarm_done_button_bg" android:foreground="?android:attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center" android:text="✓  I'm done eating" android:textColor="#388E3C" android:textSize="16sp" android:textStyle="bold" android:visibility="gone" />

        <!-- Snooze -->
        <TextView android:id="@+id/alarmSnoozeButton" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="8dp" android:background="@drawable/alarm_primary_button_bg" android:foreground="?android:attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center" android:text="Snooze 30 seconds" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />

        <!-- Stop -->
        <TextView android:id="@+id/alarmStopButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:background="@drawable/alarm_stop_outline_button_bg" android:foreground="?android:attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center" android:text="Stop alarm" android:textColor="#A32D2D" android:textSize="14sp" android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>